# Connection string used by src/store.py, src/retrieve.py and the test suite.
# Default points at the postgres+pgvector container shipped in docker-compose.yml.
# DO NOT commit a .env file — only this example.
DATABASE_URL=postgresql+psycopg2://rag:rag@localhost:5432/rag

# sentence-transformers model. Pinned for CI determinism.
# 384 dims, 80MB, runs on CPU in ~10ms/chunk.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional — only used if you wire the answer generation step to Ollama.
# The rubric mocks this layer, so you can leave it empty without breaking CI.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
